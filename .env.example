APP_NAME=CAF

# ── Porte esposte sull'host ────────────────────────────────────────────────
APP_PORT=80
VITE_PORT=5173
VITE_SERVER_IP=localhost
DB_EXTERNAL_PORT=3306
DB_TEST_EXTERNAL_PORT=3307
REDIS_EXTERNAL_PORT=6379

# ── Utente Docker (deve corrispondere all'uid dell'utente host) ────────────
# Esegui: id -u && id -g  per ottenere i valori corretti
UID=1000
GID=1000

# ── Seed utenti di default ─────────────────────────────────────────────────
SEED_SUPERADMIN_EMAIL=superadmin@email.com
SEED_ADMIN_EMAIL=admin@email.com
SEED_EMPLOYEE_EMAIL=employee@email.com
SEED_CLIENT_EMAIL=client@email.com

# ── Applicazione ───────────────────────────────────────────────────────────
APP_ENV=local
APP_KEY=                            # generato automaticamente al primo avvio se vuoto
APP_DEBUG=true
APP_URL=http://localhost

RUN_MIGRATIONS=1
RUN_SEEDERS=1

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

VITE_DATE_LOCALE=it-IT
VITE_APP_NAME="${APP_NAME}"

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ── Log ────────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database (MySQL — servizio Docker 'caf_db') ────────────────────────────
DB_CONNECTION=mysql
DB_HOST=caf_db
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root_secret

# ── Database di test (servizio Docker 'caf_db_test') ──────────────────────
DB_TEST_DATABASE=laravel_test
DB_TEST_USERNAME=laravel
DB_TEST_PASSWORD=secret

# ── Sessioni / Cache / Code ────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── Redis (servizio Docker 'caf_redis') ────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=caf_redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ───────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── AWS (non usato in locale) ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Passport ───────────────────────────────────────────────────────────────
# Chiavi RSA: genera con:  docker compose exec app php artisan passport:keys
PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=
PASSPORT_PKCE_CLIENT_ID=            # genera con: php artisan passport:client --public
PASSPORT_PKCE_REDIRECT_URI=com.cafapp://callback
